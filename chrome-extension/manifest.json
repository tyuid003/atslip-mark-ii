{
  "manifest_version": 3,
  "name": "ATslip Side Panel",
  "version": "0.1.0",
  "description": "ส่วนขยาย ATslip แบบ side panel — สแกนสลิป จับคู่ เติม/ดึงเครดิต และฟังก์ชันเสริม (สมัครสมาชิก/เปลี่ยนรหัสผ่าน) โดยไม่ต้อง login",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.atslip.biz/*",
    "https://chat.line.biz/*",
    "https://api.ipify.org/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "เปิด ATslip Side Panel",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.line.biz/*"],
      "js": ["src/content/line-biz.js"],
      "css": ["src/content/line-biz.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
